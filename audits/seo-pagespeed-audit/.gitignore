# Secrets — never commit
.env
.env.local

# Raw API dumps — large, regenerate-able. Keep .keep for the dir.
data/psi-raw/*/
!data/psi-raw/.keep

# Python build artefacts
__pycache__/
*.pyc
.venv/
venv/

# OS noise
.DS_Store

# Prompt patch scratch artefacts — not commit material
fast_track-prompt-patch*.md
fast_track-prompt-patch*.zip
