# SEO + PageSpeed Audit — environment template
# Copy this file to .env and fill in real values. .env is gitignored.

# ─── REQUIRED ───────────────────────────────────────────────────────────────
# Google PageSpeed Insights API key
# Free tier: 25,000 queries/day, 400 QPS
# Get: https://developers.google.com/speed/docs/insights/v5/get-started
# A single Google Cloud API key with PSI + CrUX APIs enabled covers both.
PSI_API_KEY=

# ─── OPTIONAL ───────────────────────────────────────────────────────────────
# Chrome UX Report API key (often the same as PSI_API_KEY).
# Only used as a fallback when PSI returns no URL-level field data.
# Get: https://developer.chrome.com/docs/crux/api
CRUX_API_KEY=

# GA4 access token + property IDs for traffic-weighted URL sampling.
# If absent, the audit falls back to repo-derived URL sampling.
GA4_ACCESS_TOKEN=
GA4_PROPERTY_IDS=

# ─── KNOBS ──────────────────────────────────────────────────────────────────
# Inter-call delay in ms (be a good citizen even though quota allows more).
PSI_REQUEST_DELAY_MS=200

# Output directory for this audit run (relative to repo root).
AUDIT_OUTPUT_DIR=Sanjow-Ventures/design-system/audits/seo-pagespeed-audit
